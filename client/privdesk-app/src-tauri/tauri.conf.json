{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PrivDesk",
  "version": "1.0.0",
  "identifier": "com.privdesk.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "PrivDesk",
        "width": 420,
        "height": 640,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/icon.ico"
    ],
    "resources": [
      "frpc.exe"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser"
      }
    }
  }
}
