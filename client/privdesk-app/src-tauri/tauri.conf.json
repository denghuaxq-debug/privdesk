{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PrivDesk",
  "version": "1.1.1",
  "identifier": "com.privdesk.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "PrivDesk",
        "width": 420,
        "height": 640,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [],
    "icon": [
      "icons/icon.ico",
      "icons/icon.icns",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ]
  }
}
